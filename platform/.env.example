# Copy to .env and adjust. `docker compose --env-file .env` reads this.

# --- Postgres (consumed by the postgres image AND the app URL below) ---------
POSTGRES_USER=vizor
POSTGRES_PASSWORD=vizor
POSTGRES_DB=vizor

# --- App (VE_ prefix → edge.core.config.Settings) ---------------------------
VE_ENV=dev
VE_DATABASE_URL=postgresql+asyncpg://vizor:vizor@postgres:5432/vizor
VE_REDIS_URL=redis://redis:6379/0

# Secrets — CHANGE THESE in production.
VE_JWT_SECRET=change-me-to-a-long-random-string-min-32-bytes
VE_SECRETS_KEY=change-me-another-long-random-string

# First-run admin (created if the users table is empty).
# Use a real TLD — email validation rejects reserved domains like .local.
VE_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
VE_BOOTSTRAP_ADMIN_PASSWORD=changeme123

# Licensing — bundle the vendor PUBLIC key; provide a client token in prod.
VE_LICENSE_PUBLIC_KEY_FILE=license_pub.pem
# VE_LICENSE_TOKEN_FILE=license.jwt

# CORS (frontend origins)
VE_CORS_ORIGINS=["http://localhost:3000"]

# --- Object storage ---------------------------------------------------------
# Default = local disk (works out of the box). To use RustFS (S3), set:
VE_STORAGE_BACKEND=local
VE_STORAGE_LOCAL_DIR=./data/storage
# VE_STORAGE_BACKEND=s3
# VE_S3_ENDPOINT=http://rustfs:9000
# VE_S3_BUCKET=vizor
# VE_S3_ACCESS_KEY=rustfsadmin
# VE_S3_SECRET_KEY=rustfsadmin
# VE_S3_REGION=us-east-1

# --- RustFS server credentials (consumed by the rustfs image) ---------------
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
