#!/usr/bin/env python3
"""create-scenario — generate a complete standalone Vizor scenario repo.

Given a scenario name, produce a self-contained repo (its OWN git repo) with:
  - backend/   FastAPI on the edge boilerplate (own DB + port)
  - frontend/  clean DashCode Next.js scaffold (own views/ + menu.js)
  - platform/  a VENDORED copy of scenarios/platform (edge backend + shared web UI)
  - docker-compose.yml + .env + README + sync-platform.sh

Host ports are auto-assigned from tools/ports-registry.json (slug -> index N) so
many scenario stacks coexist on one machine.

Usage:
  tools/create-scenario "PPE Detection"
  tools/create-scenario "PPE Detection" --slug ppe --out ../
  tools/create-scenario "Crowd Analytics" --no-git
"""

from __future__ import annotations

import argparse
import json
import re
import shutil
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent          # scenarios/
TEMPLATE = ROOT / "template"
PLATFORM = ROOT / "platform"
REGISTRY = ROOT / "tools" / "ports-registry.json"

# Directories/files to skip when vendoring platform + when copying the template.
VENDOR_IGNORE = shutil.ignore_patterns(
    ".venv", "__pycache__", "*.pyc", "*.egg-info", "node_modules", ".next", ".git", "data",
)
# Extensions we never token-substitute (binary / lockfiles).
SKIP_TOKENIZE_SUFFIX = {".png", ".jpg", ".jpeg", ".ico", ".gif", ".woff", ".woff2", ".ttf", ".lock"}


def slugify(name: str) -> str:
    s = re.sub(r"[^a-z0-9]+", "-", name.strip().lower()).strip("-")
    return re.sub(r"-{2,}", "-", s)


def ports_for(index: int) -> dict[str, int]:
    n = index
    return {
        "__PORT_BACKEND__": 8000 + n,
        "__PORT_FRONTEND__": 3000 + n,
        "__PORT_POSTGRES__": 5432 + n,
        "__PORT_REDIS__": 6379 + n,
        "__PORT_QDRANT__": 6333 + n,
        "__PORT_RUSTFS1__": 9000 + 2 * n,
        "__PORT_RUSTFS2__": 9001 + 2 * n,
        "__PORT_MAILDEV_SMTP__": 1025 + n,
        "__PORT_MAILDEV_UI__": 1080 + n,
        "__PORT_MEDIAMTX_RTSP__": 8554 + n,
        "__PORT_MEDIAMTX_WEBRTC__": 8889 + n,
        "__PORT_MEDIAMTX_HLS__": 8888 + n,
        "__PORT_MEDIAMTX_API__": 9997 + n,
    }


def allocate_index(slug: str) -> int:
    reg = json.loads(REGISTRY.read_text()) if REGISTRY.exists() else {}
    if slug in reg and isinstance(reg[slug], int):
        return reg[slug]  # idempotent: reuse this scenario's block
    used = {v for v in reg.values() if isinstance(v, int)}
    idx = 0
    while idx in used:
        idx += 1
    reg[slug] = idx
    REGISTRY.write_text(json.dumps(reg, indent=2) + "\n")
    return idx


def tokenize_tree(root: Path, tokens: dict[str, str]) -> None:
    for p in root.rglob("*"):
        if not p.is_file() or p.suffix.lower() in SKIP_TOKENIZE_SUFFIX:
            continue
        try:
            text = p.read_text(encoding="utf-8")
        except (UnicodeDecodeError, ValueError):
            continue  # binary — skip
        if "__" not in text:
            continue
        for k, v in tokens.items():
            text = text.replace(k, v)
        p.write_text(text, encoding="utf-8")


def main() -> int:
    ap = argparse.ArgumentParser(description="Generate a standalone Vizor scenario repo.")
    ap.add_argument("name", help='Scenario display name, e.g. "PPE Detection"')
    ap.add_argument("--slug", help="Identifier slug (default: slugify(name))")
    ap.add_argument("--out", default=str(ROOT.parent), help="Parent dir for the new repo (default: scenarios/'s parent)")
    ap.add_argument("--no-git", action="store_true", help="Skip git init + initial commit")
    args = ap.parse_args()

    name = args.name.strip()
    slug = args.slug or slugify(name)
    if not re.fullmatch(r"[a-z0-9][a-z0-9-]*", slug):
        print(f"invalid slug '{slug}' (use lowercase letters, digits, hyphens)", file=sys.stderr)
        return 2
    db = slug.replace("-", "_")
    out_dir = Path(args.out).expanduser().resolve() / slug

    if not TEMPLATE.is_dir() or not (PLATFORM / "edge").is_dir():
        print("template/ or platform/ missing — run from a scenarios checkout.", file=sys.stderr)
        return 2
    if out_dir.exists():
        print(f"refusing to overwrite existing path: {out_dir}", file=sys.stderr)
        return 1

    index = allocate_index(slug)
    tokens = {"__SLUG__": slug, "__NAME__": name, "__DB__": db}
    tokens.update({k: str(v) for k, v in ports_for(index).items()})

    print(f"→ scenario '{name}'  slug={slug}  db={db}  port-index={index}")
    print(f"→ backend :{tokens['__PORT_BACKEND__']}  frontend :{tokens['__PORT_FRONTEND__']}  → {out_dir}")

    # 1. copy template
    shutil.copytree(TEMPLATE, out_dir, ignore=VENDOR_IGNORE)
    # 2. vendor platform
    shutil.copytree(PLATFORM, out_dir / "platform", ignore=VENDOR_IGNORE)
    # 3. tokenize contents (template files only; platform is copied verbatim)
    for sub in ("backend", "frontend"):
        tokenize_tree(out_dir / sub, tokens)
    # root-level template files
    for f in ("docker-compose.yml", ".env.example", "README.md", "sync-platform.sh"):
        fp = out_dir / f
        if fp.exists():
            t = fp.read_text(encoding="utf-8")
            for k, v in tokens.items():
                t = t.replace(k, v)
            fp.write_text(t, encoding="utf-8")
    # 4. .env from .env.example
    shutil.copyfile(out_dir / ".env.example", out_dir / ".env")

    # 5. git init + commit
    if not args.no_git:
        try:
            subprocess.run(["git", "init", "-q"], cwd=out_dir, check=True)
            subprocess.run(["git", "add", "-A"], cwd=out_dir, check=True)
            subprocess.run(
                ["git", "commit", "-q", "-m", f"chore: scaffold {name} scenario app (vizor create-scenario)"],
                cwd=out_dir, check=True,
            )
        except Exception as exc:  # noqa: BLE001
            print(f"(git init/commit skipped: {exc})")

    print("\n✓ done.\n")
    print("next steps:")
    print(f"  cd {out_dir}")
    print("  docker compose up -d --build")
    print(f"  # frontend  http://localhost:{tokens['__PORT_FRONTEND__']}")
    print(f"  # backend   http://localhost:{tokens['__PORT_BACKEND__']}/api/v1")
    print("  # login     support@geniusvision.in / Gvd@6001")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
