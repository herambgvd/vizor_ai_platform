# Shared-infra credentials. These MUST match the VE_* values in every scenario's
# .env.shared (same DB user/password, same S3 keys) so the scenarios can connect.
POSTGRES_USER=vizor
POSTGRES_PASSWORD=vizor
# Default maintenance DB created by the postgres image on first boot. Scenario
# databases (frs / suspect / …) are created on demand by each scenario backend.
POSTGRES_DB=postgres

# RustFS (S3-compatible) root credentials. Scenarios use these as VE_S3_ACCESS_KEY /
# VE_S3_SECRET_KEY and each gets its own bucket (vizor-<slug>, auto-created).
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
