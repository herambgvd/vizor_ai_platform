# Anti-spoof / liveness (client-supplied best_model.onnx). This export is a
# 2-class classifier at 128x128 (NOT the 80x80 3-class MiniFASNet vizor_nvr used):
#   input  "input"  = 1x3x128x128 (dynamic batch), ImageNet-normalised RGB
#   output "output" = [live_logit, spoof_logit]  → class 0 = LIVE, class 1 = SPOOF
# The plugin softmaxes and reads P(live) = softmax[0] (FRS_LIVE_CLASS_INDEX=0).
name: "antispoofing"
platform: "onnxruntime_onnx"
max_batch_size: 16
input  [ { name: "input"  data_type: TYPE_FP32 dims: [ 3, 128, 128 ] } ]
output [ { name: "output" data_type: TYPE_FP32 dims: [ 2 ] } ]
instance_group [ { count: 1 kind: KIND_GPU } ]
dynamic_batching { preferred_batch_size: [ 4, 8, 16 ] max_queue_delay_microseconds: 2000 }
