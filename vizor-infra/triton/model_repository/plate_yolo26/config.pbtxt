# ANPR plate detector — user-supplied YOLO26n (single "plate" class). Runs on the
# GPU via the ONNX Runtime CUDA provider. Output is RAW [1,5,8400] = (cx,cy,w,h,score)
# — NMS is done client-side (unlike the NMS-free yolo26 vehicle model).
# NOTE: for a pure-TensorRT engine (like yolo26) pre-build a .plan with trtexec and
# switch platform to "tensorrt_plan"; the ORT-TRT execution accelerator is skipped
# here because its at-load engine build hangs on this GPU (Blackwell sm_120).
name: "plate_yolo26"
platform: "onnxruntime_onnx"
max_batch_size: 0
input  [ { name: "images"  data_type: TYPE_FP32 dims: [ 1, 3, 640, 640 ] } ]
output [ { name: "output0" data_type: TYPE_FP32 dims: [ 1, 5, 8400 ] } ]
instance_group [ { count: 2 kind: KIND_GPU } ]
